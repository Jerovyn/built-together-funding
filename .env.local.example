# --- Site / contact (public) ---
# Canonical URL for metadata and absolute links
NEXT_PUBLIC_SITE_URL=https://builttogetherfunding.com

# Optional: shown on contact/footer; tel: uses E.164-friendly value
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_PHONE_DISPLAY=
# Public inbox on site footer + contact page (Google Workspace)
NEXT_PUBLIC_CONTACT_EMAIL=contact@builttogetherfunding.com
# Optional: business address shown in the footer (builds trust; recommended before paid ads)
NEXT_PUBLIC_BUSINESS_ADDRESS=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
# From address applicants see (must be verified in Resend)
RESEND_FROM_EMAIL=contact@builttogetherfunding.com
# Optional: defaults to NEXT_PUBLIC_CONTACT_EMAIL if unset
RESEND_REPLY_TO_EMAIL=contact@builttogetherfunding.com
# All internal alerts: apply, booking, ISO (Google Workspace subs inbox)
INTERNAL_NOTIFY_EMAIL=subs@builttogetherfunding.com

# --- Twilio (SMS, optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
INTERNAL_NOTIFY_PHONE=

# --- Analytics / ads (optional) ---
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# --- Admin CRM (/admin/login/) ---
# Password field only — NOT an email address. Same string you type at /admin/login/
ADMIN_DASHBOARD_SECRET=

# --- Google Calendar + Meet (funding review bookings) ---
# From Google Cloud → APIs & Services → Credentials → OAuth client (Web)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: defaults to "primary" calendar of the connected account
GOOGLE_CALENDAR_ID=primary
