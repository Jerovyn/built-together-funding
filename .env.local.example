# --- Site / contact (public) ---
# Canonical URL for metadata and absolute links (e.g. https://your-domain.com)
NEXT_PUBLIC_SITE_URL=

# Optional: shown on contact/footer; tel: uses E.164-friendly value
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_PHONE_DISPLAY=
NEXT_PUBLIC_CONTACT_EMAIL=
# Optional: business address shown in the footer (builds trust; recommended before paid ads)
NEXT_PUBLIC_BUSINESS_ADDRESS=

# --- Supabase ---
# Public URL of your project (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
# Anon key: safe for browser if you add client-side Supabase later; never use service role in the client
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SERVER ONLY (API routes, server components). Never commit to client bundles or expose publicly.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INTERNAL_NOTIFY_EMAIL=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
INTERNAL_NOTIFY_PHONE=

# --- Analytics / ads (optional; scripts load only when set) ---
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# --- Admin CRM (session login) ---
# Password for /admin/login/ — same value signs the session cookie.
# Protects /admin/leads/, /admin/appointments/, and related CRM routes.
ADMIN_DASHBOARD_SECRET=
